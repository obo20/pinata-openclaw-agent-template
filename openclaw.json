{
  "identity": {
    "name": "Alchemy Agent",
    "theme": "on-chain intelligence",
    "emoji": "⚗️"
  },
  "agent": {
    "workspace": "./workspace"
  },
  "skills": {
    "entries": {
      "alchemy-api": {
        "enabled": true,
        "env": {
          "ALCHEMY_API_KEY": "${ALCHEMY_API_KEY}"
        }
      }
    }
  },
  "cron": {
    "enabled": true,
    "store": "./cron/jobs.json"
  }
}
